# 복사해서 .env 로 사용: cp .env.example .env
# ── 데이터베이스 (데모는 컨테이너 pfdb, 운영은 고객 pfdb로 교체) ──
PFDB_HOST=pfdb
PFDB_PORT=5432
PFDB_NAME=pfdb
PFDB_USER=postgres
PFDB_PASSWORD=postgres

# ── Ollama (로컬 추론) ──
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=gemma:2b        # 사전 다운로드한 모델 태그로 교체 (예: gemma2:2b, gemma:7b-q4)

# ── 분석 파라미터 (설계문서 §3.2) ──
RISK_THRESHOLD=35            # 리포트 적재 최소 점수
WORKHOUR_START=8             # 업무시간 시작(야간판정용)
WORKHOUR_END=19             # 업무시간 끝
ANALYSIS_WINDOW_HOURS=168    # 분석 창(기본 7일)

# ── 데모 대상 라이선스 ──
DEMO_LICENSE_CODE=          # 시드 데이터의 license_code 로 채울 것
POLICY_SEPARATE_PID=1     # media_separate 정책 pid(데모 seed=1)
